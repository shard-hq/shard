# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=xxx
# development | production | test
NODE_ENV=development
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug
# Upload badges from src/assets/badges to the application's emoji set on boot
SYNC_EMOJIS=true

# Internal gateway shards. Each shard handles up to 2500 guilds.
# Pick a value that covers your expected guild count:
# 1 shard  →     1 -  2500 guilds
# 2 shards →  2501 -  5000 guilds
# 3 shards →  5001 -  7500 guilds
# 4 shards →  7501 - 10000 guilds
# 5 shards → 10001 - 12500 guilds
SHARD_COUNT=1
